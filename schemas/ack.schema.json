{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ACK Message",
  "type": "object",
  "properties": {
    "type": { "type": "string", "const": "ack" },
    "text": { "type": "string" },
    "voice_style": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "query_intent": { "type": "string" },
    "estimated_wait_sec": { "type": "integer" },
    "related_query": { "type": "string" }
  },
  "required": ["type", "text", "timestamp", "query_intent"]
}