# 阿里云百炼 API 配置
# 获取 API Key: https://help.aliyun.com/model-studio/get-api-key
DASHSCOPE_API_KEY=sk-fb1a1b32bf914059a043ee4ebd1c845a

# 地域配置 (beijing, singapore, virginia)
LLM_REGION=beijing

# 默认模型 (qwen3.5-flash, qwen3.5-plus, qwen-plus, qwen-max)
LLM_MODEL=qwen3.5-plus

# 思考模式配置 (true, false, auto)
# auto: 根据场景复杂度自动判断
# true: 强制启用
# false: 强制禁用
LLM_ENABLE_THINKING=auto

# 调试模式 (true, false)
LLM_DEBUG=false

# 模型参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=30000

# 重试配置
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1000
